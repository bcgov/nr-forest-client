{
  "name": "forest-client-frontend",
  "version": "0.0.1",
  "description": "Frontend for Forests Client Management System project",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bcgov/nr-forest-client.git"
  },
  "keywords": [
    "openshift",
    "pipeline",
    "node",
    "typescript",
    "js",
    "devops"
  ],
  "author": "Maria Martinez, Paulo Cruz, and Fernando Terra.",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/bcgov/nr-forest-client/issues"
  },
  "homepage": "https://github.com/bcgov/nr-forest-client",
  "private": true,
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "scripts": {
    "start": "vite --host --port 3000",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "cross-env VITE_NODE_ENV=test VITE_GREEN_DOMAIN=green-domain.com start-server-and-test stub http://127.0.0.1:8080 start",
    "preview:test": "cross-env VITE_NODE_ENV=test VITE_GREEN_DOMAIN=green-domain.com start-server-and-test stub:test http://127.0.0.1:8080 start",
    "preview:app": "cross-env VITE_NODE_ENV=test vite --host --port 3000",
    "typecheck": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --fix --ignore-path .gitignore",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "stub": "wiremock --enable-stub-cors --global-response-templating --port 8080 --https-port 8081 --root-dir ./stub --verbose",
    "generate:stub:test": "ts-node -O '{\"module\":\"commonjs\"}' stub-tests.ts",
    "prestub:test": "npm run generate:stub:test",
    "stub:test": "wiremock --enable-stub-cors --global-response-templating --port 8080 --https-port 8081 --root-dir ./stub-tests --verbose",
    "precoverage": "npm run test:report:clean",
    "coverage": "npm run test:unit && npm run test:component && npm run test:e2e",
    "postcoverage": "npm run test:report:merge",
    "test:component": "VITE_MODE=test cypress run --component --headless",
    "posttest:component": "mv reports/.nyc_report reports/component",
    "test:unit": "cross-env VITE_NODE_ENV=test NODE_ENV=test vitest run --coverage",
    "posttest:unit": "mv reports/.vite_report reports/unit",
    "test:e2e": "cross-env VITE_NODE_ENV=test VITE_GREEN_DOMAIN=green-domain.com VITE_FEATURE_FLAGS={} start-server-and-test preview:test http://127.0.0.1:3000 'cypress run --headless'",
    "posttest:e2e": "mv reports/.nyc_report reports/e2e",
    "pretest:report:merge": "rm -rf reports-merge && mkdir -p reports-merge && for name in component e2e unit; do cp reports/$name/coverage-final.json reports-merge/$name.json; done",
    "test:report:merge": "mkdir -p .nyc_output && rm -rf coverage && nyc --config nyc.config.json merge reports-merge &&  mv coverage.json .nyc_output/out.json && nyc --config nyc.config.json report --reporter lcov --reporter text-summary --report-dir coverage --temp-dir .nyc_output",
    "test:report:clean": "rm -rf reports && mkdir -p reports/.nyc_output/processinfo && mkdir -p coverage",
    "test:build": "cross-env VITE_MODE=test VITE_NODE_ENV=test VITE_GREEN_DOMAIN=green-domain.com start-server-and-test preview http://127.0.0.1:3000 'cypress open'",
    "test:flush": "rm -rf reports && rm -rf .nyc_output && rm -rf coverage && rm -rf reports-merge",
    "posttest:flush": "npm run coverage",
    "test:unit:devtools": "cross-env VITE_NODE_ENV=test NODE_ENV=test vitest run --inspect-brk --pool threads --poolOptions.threads.singleThread"
  },
  "dependencies": {
    "@bcgov-nr/nr-fsa-theme": "^1.1.3",
    "@bcgov/bc-sans": "^2.1.0",
    "@carbon/icons-vue": "^10.99.1",
    "@carbon/pictograms": "^12.42.0",
    "@carbon/styles": "^1.67.0",
    "@carbon/web-components": "^2.12.0",
    "@vueuse/core": "^14.0.0",
    "aws-amplify": "^6.16.3",
    "axios": "^1.15.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.0.0",
    "fast-json-patch": "^3.1.1",
    "vue": "^3.5.13",
    "vue-dompurify-html": "^5.3.0",
    "vue-router": "^5.0.4",
    "vue-the-mask": "^0.11.1"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^4.0.3",
    "@eslint/js": "^9.39.4",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.0.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-istanbul": "^3.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.9.0",
    "cross-env": "^10.0.0",
    "cypress": "^15.14.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-cypress": "^6.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.0.0",
    "istanbul-lib-coverage": "^3.2.0",
    "istanbul-lib-instrument": "^6.0.0",
    "jsdom": "^29.0.0",
    "lcov-result-merger": "^6.0.0",
    "nyc": "^18.0.0",
    "prettier": "^3.5.3",
    "sass": "^1.97.3",
    "sass-loader": "^16.0.7",
    "start-server-and-test": "^3.0.0",
    "ts-node": "^10.9.1",
    "typescript": "~5.9.0",
    "unplugin-icons": "^22.1.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^5.4.10",
    "vite-plugin-istanbul": "^5.0.0",
    "vitest": "^3.0.5",
    "vue-component-type-helpers": "^3.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-svg-loader": "^0.16.0",
    "vue-tsc": "^3.0.0",
    "wiremock": "^3.13.2"
  },
  "overrides": {
    "dompurify": "^3.4.0",
    "uuid": "^14.0.0",
    "picomatch@^4.0.0": "^4.0.4",
    "flatted": "^3.4.2",
    "yaml": "^2.8.3",
    "immutable": "5.1.5",
    "fast-xml-parser": "5.7.1",
    "webpack@<5.105.1": "5.105.1",
    "lodash@^4.0.0": "^4.18.1",
    "qs": "6.15.1",
    "follow-redirects": "^1.16.0",
    "postcss": "^8.5.10",
    "tmp": "^0.2.4",
    "js-yaml": "^4.1.1"
  },
  "nyc": {
    "check-coverage": true,
    "lines": 40
  }
}
