{
  "extends": "../tsconfig.cypress.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2020",
    "types": [
      "node",
      "cypress"
    ]
  },
  "include": [
    "./cypress.config.ts",
    "./**/*.ts",
    "../cypress.config.ts",
    "../cypress/**/*.ts",
    "../tests/components/**/*.ts",
    "../env.d.ts",
    "../src/**/*",
    "../src/**/*.vue",
    "../components.d.ts"
  ]
}
