{
  "mappings": [
    {
      "name": "Client BC Registry",
      "priority": 1,
      "request": {
        "method": "GET",
        "urlPattern": "/api/clients/bc-registry/[^/]+"
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "bodyFileName": "response-client-bc-registry.json",
        "fixedDelayMilliseconds": 2000
      }
    },
    {
      "name": "Client BC Registry - empty",
      "priority": 1,
      "request": {
        "method": "GET",
        "urlPattern": "/api/clients/bc-registry/empty"
      },
      "response": {
        "status": 404,
        "headers": {
          "Content-Type": "application/json"
        },
        "fixedDelayMilliseconds": 2000
      }
    }
  ]
}
